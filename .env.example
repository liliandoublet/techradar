# === AI ===
# Get your free API key at https://aistudio.google.com
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxx

# === EMAIL ===
# Get your free API key at https://sendgrid.com
# The SENDER_EMAIL must be verified in SendGrid Sender Authentication
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDER_EMAIL=your@gmail.com
DIGEST_RECIPIENT=your@gmail.com

# === AGENT SETTINGS ===
# Topics used by Gemini to score article relevance (0-10)
TOPICS=AI,Python,Cloud,LLM
MAX_ARTICLES=10

# === AWS ===
# AWS credentials are NOT stored here.
# Configure them via the AWS CLI: aws configure
# They are read automatically from ~/.aws/credentials by boto3.
AWS_REGION=eu-west-1
S3_BUCKET_NAME=techradar-cache